<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/vendor_dark_bg"
    android:clipToPadding="false"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="26dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="132dp"
            android:background="@drawable/bg_top_dark"
            android:gravity="top|center_horizontal"
            android:orientation="vertical"
            android:paddingTop="34dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Duyệt cửa hàng"
                android:textColor="@color/vendor_dark_text_primary"
                android:textSize="26sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="-48dp"
            android:background="@drawable/bg_admin_panel"
            android:elevation="8dp"
            android:orientation="vertical"
            android:padding="22dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvAdminPendingCount"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Hồ sơ chờ duyệt"
                    android:textColor="@color/vendor_dark_text_primary"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_admin_status_pending"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="7dp"
                    android:text="0 mới"
                    android:textColor="#B24C08"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Chạm vào một cửa hàng để xem chi tiết và phê duyệt."
                android:textColor="@color/vendor_dark_text_secondary"
                android:textSize="14sp" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnAdminStatusPending"
                        android:layout_width="wrap_content"
                        android:layout_height="38dp"
                        android:minWidth="0dp"
                        android:text="Chờ duyệt"
                        android:textAllCaps="false"
                        android:textSize="12sp"
                        app:cornerRadius="12dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnAdminStatusApproved"
                        android:layout_width="wrap_content"
                        android:layout_height="38dp"
                        android:layout_marginStart="8dp"
                        android:minWidth="0dp"
                        android:text="Đã duyệt"
                        android:textAllCaps="false"
                        android:textSize="12sp"
                        app:cornerRadius="12dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnAdminStatusRejected"
                        android:layout_width="wrap_content"
                        android:layout_height="38dp"
                        android:layout_marginStart="8dp"
                        android:minWidth="0dp"
                        android:text="Từ chối"
                        android:textAllCaps="false"
                        android:textSize="12sp"
                        app:cornerRadius="12dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnAdminStatusBanned"
                        android:layout_width="wrap_content"
                        android:layout_height="38dp"
                        android:layout_marginStart="8dp"
                        android:minWidth="0dp"
                        android:text="Đã khóa"
                        android:textAllCaps="false"
                        android:textSize="12sp"
                        app:cornerRadius="12dp" />
                </LinearLayout>
            </HorizontalScrollView>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvAdminPendingShops"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:nestedScrollingEnabled="false" />

            <TextView
                android:id="@+id/tvAdminPendingEmpty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:gravity="center"
                android:paddingVertical="28dp"
                android:text="Không có cửa hàng chờ duyệt"
                android:textColor="@color/text_secondary"
                android:textSize="15sp"
                android:visibility="gone" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAdminShopsLoadMore"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:layout_marginTop="14dp"
                android:backgroundTint="@color/white"
                android:text="Tải thêm"
                android:textAllCaps="false"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:visibility="gone"
                app:cornerRadius="14dp"
                app:strokeColor="@color/profile_divider"
                app:strokeWidth="1dp" />
        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>