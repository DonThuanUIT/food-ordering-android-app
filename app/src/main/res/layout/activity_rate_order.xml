<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F8FAFC">

    <!-- Custom Toolbar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#FFFFFF"
        app:navigationIcon="@drawable/ic_back"
        app:navigationIconTint="#0F172A"
        app:title="Đánh giá đơn hàng 🌟"
        app:titleTextColor="#0F172A"
        app:elevation="2dp" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="16dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 0. Selection Options Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Bạn muốn đánh giá phần nào? 🤔"
                        android:textColor="#0F172A"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <com.google.android.material.checkbox.MaterialCheckBox
                            android:id="@+id/cb_rate_order"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Vận chuyển"
                            android:textColor="#1E293B"
                            android:buttonTint="@color/brand_orange"
                            android:checked="true"/>

                        <com.google.android.material.checkbox.MaterialCheckBox
                            android:id="@+id/cb_rate_shop"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Cửa hàng"
                            android:textColor="#1E293B"
                            android:buttonTint="@color/brand_orange"
                            android:checked="true"/>

                        <com.google.android.material.checkbox.MaterialCheckBox
                            android:id="@+id/cb_rate_food"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Món ăn"
                            android:textColor="#1E293B"
                            android:buttonTint="@color/brand_orange"
                            android:checked="true"/>
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- 1. Order & Delivery Review Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_rate_order"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1. Vận chuyển &amp; Giao nhận 🛵"
                        android:textColor="#0F172A"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="6dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Đánh giá chất lượng giao hàng, tốc độ và cách đóng gói đồ ăn"
                        android:textColor="#64748B"
                        android:textSize="13sp"
                        android:layout_marginBottom="16dp"/>

                    <RatingBar
                        android:id="@+id/rating_bar_order"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:numStars="5"
                        android:stepSize="1"
                        android:rating="5"
                        android:progressTint="@color/brand_orange"
                        android:progressBackgroundTint="#CBD5E1"
                        android:layout_marginBottom="16dp"
                        style="?android:attr/ratingBarStyle"/>

                    <EditText
                        android:id="@+id/et_comment_order"
                        android:layout_width="match_parent"
                        android:layout_height="100dp"
                        android:background="@drawable/bg_edittext"
                        android:hint="Nhập nhận xét về vận chuyển (ví dụ: giao nhanh, shipper thân thiện...)"
                        android:textColor="#0F172A"
                        android:textColorHint="#94A3B8"
                        android:textSize="14sp"
                        android:gravity="top"
                        android:padding="16dp"
                        android:inputType="textMultiLine"
                        android:importantForAutofill="no"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- 2. Shop & Service Review Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_rate_shop"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:id="@+id/tv_rate_shop_header"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="2. Dịch vụ Cửa hàng 🏪"
                        android:textColor="#0F172A"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="6dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Đánh giá chất lượng phục vụ và thời gian chuẩn bị của quán ăn"
                        android:textColor="#64748B"
                        android:textSize="13sp"
                        android:layout_marginBottom="16dp"/>

                    <RatingBar
                        android:id="@+id/rating_bar_shop"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:numStars="5"
                        android:stepSize="1"
                        android:rating="5"
                        android:progressTint="@color/brand_orange"
                        android:progressBackgroundTint="#CBD5E1"
                        android:layout_marginBottom="16dp"
                        style="?android:attr/ratingBarStyle"/>

                    <EditText
                        android:id="@+id/et_comment_shop"
                        android:layout_width="match_parent"
                        android:layout_height="100dp"
                        android:background="@drawable/bg_edittext"
                        android:hint="Nhập nhận xét về quán ăn (ví dụ: chuẩn bị nhanh, đồ ăn sạch sẽ...)"
                        android:textColor="#0F172A"
                        android:textColorHint="#94A3B8"
                        android:textSize="14sp"
                        android:gravity="top"
                        android:padding="16dp"
                        android:inputType="textMultiLine"
                        android:importantForAutofill="no"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- 3. Foods Rating Header -->
            <TextView
                android:id="@+id/tv_rate_food_header"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="3. Đánh giá Món ăn ngon miệng 🍔"
                android:textColor="#0F172A"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginStart="4dp"
                android:layout_marginBottom="12dp"/>

            <!-- RecyclerView of foods to rate -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_food_ratings"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:layout_marginBottom="16dp"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Submit Button -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardElevation="8dp"
        app:cardBackgroundColor="#FFFFFF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_submit_review"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Gửi đánh giá"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:backgroundTint="@color/brand_orange"
                app:cornerRadius="12dp"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

</LinearLayout>
