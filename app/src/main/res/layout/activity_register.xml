<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/register"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    tools:context=".ui.auth.RegisterActivity">

    <View
        android:id="@+id/topBackground"
        android:layout_width="0dp"
        android:layout_height="250dp"
        android:background="#FF7A21"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/imgIllustration"
        android:layout_width="140dp"
        android:layout_height="100dp"
        android:src="@drawable/img_login_hero"
        android:scaleType="fitCenter"
        android:layout_marginTop="28dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="42dp"
        android:layout_height="42dp"
        android:layout_marginStart="20dp"
        android:layout_marginTop="36dp"
        android:background="@drawable/home_bg_circle_white"
        android:contentDescription="Quay lại"
        android:padding="10dp"
        android:scaleType="centerInside"
        android:src="@drawable/ic_arrow_back_rounded"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="#FF7A21" />

    <TextView
        android:id="@+id/txtTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="sans-serif-medium"
        android:text="Đăng Ký Tài Khoản"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginTop="6dp"
        app:layout_constraintTop_toBottomOf="@id/imgIllustration"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <androidx.cardview.widget.CardView
        android:id="@+id/registerCard"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="-20dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"
        app:cardCornerRadius="28dp"
        app:cardElevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/topBackground">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingTop="20dp"
                android:paddingEnd="20dp"
                android:paddingBottom="12dp">

                <TextView
                    android:id="@+id/txtStepLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Bước 1/4"
                    android:textColor="@color/brand_orange"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtStepTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Bạn là?"
                    android:textColor="#1A1D26"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtStepSubtitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Chọn vai trò để UniEats chuẩn bị đúng thông tin cần đăng ký."
                    android:textColor="#55607A"
                    android:textSize="13sp" />

                <LinearLayout
                    android:id="@+id/layoutStepDots"
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:layout_marginTop="14dp"
                    android:orientation="horizontal">

                    <View
                        android:id="@+id/dotStepRole"
                        android:layout_width="0dp"
                        android:layout_height="6dp"
                        android:layout_marginEnd="6dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_tab_indicator" />

                    <View
                        android:id="@+id/dotStepAccount"
                        android:layout_width="0dp"
                        android:layout_height="6dp"
                        android:layout_marginEnd="6dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_edittext" />

                    <View
                        android:id="@+id/dotStepDetails"
                        android:layout_width="0dp"
                        android:layout_height="6dp"
                        android:layout_marginEnd="6dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_edittext" />

                    <View
                        android:id="@+id/dotStepPassword"
                        android:layout_width="0dp"
                        android:layout_height="6dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_edittext" />
                </LinearLayout>
            </LinearLayout>

            <ScrollView
                android:id="@+id/registerScroll"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:fillViewport="true"
                android:scrollbars="none">

                <FrameLayout
                    android:id="@+id/layoutStepContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clipChildren="false"
                    android:clipToPadding="false"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:paddingBottom="12dp">

                    <LinearLayout
                        android:id="@+id/stepRole"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <RadioGroup
                            android:id="@+id/rgRole"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <RadioButton
                                android:id="@+id/rbStudent"
                                android:layout_width="match_parent"
                                android:layout_height="74dp"
                                android:background="@drawable/bg_radio_selector"
                                android:button="@null"
                                android:checked="true"
                                android:drawableStart="@drawable/ic_profile"
                                android:drawablePadding="12dp"
                                android:gravity="center_vertical"
                                android:paddingHorizontal="18dp"
                                android:text="Sinh viên"
                                android:textColor="#1A1D26"
                                android:textSize="16sp"
                                android:textStyle="bold" />

                            <RadioButton
                                android:id="@+id/rbOwner"
                                android:layout_width="match_parent"
                                android:layout_height="74dp"
                                android:layout_marginTop="12dp"
                                android:background="@drawable/bg_radio_selector"
                                android:button="@null"
                                android:drawableStart="@drawable/ic_store"
                                android:drawablePadding="12dp"
                                android:gravity="center_vertical"
                                android:paddingHorizontal="18dp"
                                android:text="Chủ quán"
                                android:textColor="#1A1D26"
                                android:textSize="16sp"
                                android:textStyle="bold" />

                            <RadioButton
                                android:id="@+id/rbShipper"
                                android:layout_width="match_parent"
                                android:layout_height="74dp"
                                android:layout_marginTop="12dp"
                                android:background="@drawable/bg_radio_selector"
                                android:button="@null"
                                android:drawableStart="@drawable/ic_shipper"
                                android:drawablePadding="12dp"
                                android:gravity="center_vertical"
                                android:paddingHorizontal="18dp"
                                android:text="Shipper"
                                android:textColor="#1A1D26"
                                android:textSize="16sp"
                                android:textStyle="bold" />
                        </RadioGroup>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/stepAccount"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <TextView
                            style="@style/LabelStyle"
                            android:text="HỌ VÀ TÊN" />

                        <EditText
                            android:id="@+id/edtFullName"
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:layout_marginTop="8dp"
                            android:background="@drawable/bg_edittext"
                            android:hint="Nguyễn Văn A"
                            android:inputType="textPersonName"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:textColor="#222222"
                            android:textColorHint="#B8BDC9" />

                        <TextView
                            style="@style/LabelStyle"
                            android:layout_marginTop="18dp"
                            android:text="EMAIL" />

                        <EditText
                            android:id="@+id/edtEmail"
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:layout_marginTop="8dp"
                            android:background="@drawable/bg_edittext"
                            android:hint="example@gmail.com"
                            android:inputType="textEmailAddress"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:textColor="#222222"
                            android:textColorHint="#B8BDC9" />

                        <TextView
                            style="@style/LabelStyle"
                            android:layout_marginTop="18dp"
                            android:text="SỐ ĐIỆN THOẠI" />

                        <EditText
                            android:id="@+id/edtPhone"
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:layout_marginTop="8dp"
                            android:background="@drawable/bg_edittext"
                            android:hint="0123456789"
                            android:inputType="phone"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:textColor="#222222"
                            android:textColorHint="#B8BDC9" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/stepDetails"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <LinearLayout
                            android:id="@+id/layoutStudentFields"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:visibility="visible">

                            <TextView
                                style="@style/LabelStyle"
                                android:text="TÒA NHÀ" />

                            <AutoCompleteTextView
                                android:id="@+id/edtBuildingId"
                                android:layout_width="match_parent"
                                android:layout_height="52dp"
                                android:layout_marginTop="8dp"
                                android:background="@drawable/bg_edittext"
                                android:hint="Chọn tòa nhà"
                                android:inputType="none"
                                android:focusable="false"
                                android:clickable="true"
                                android:cursorVisible="false"
                                android:paddingStart="16dp"
                                android:paddingEnd="16dp"
                                android:textColor="#222222"
                                android:textColorHint="#B8BDC9" />
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/layoutVendorFields"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:visibility="gone">

                            <TextView
                                style="@style/LabelStyle"
                                android:text="TÊN CỬA HÀNG" />

                            <EditText
                                android:id="@+id/edtShopName"
                                android:layout_width="match_parent"
                                android:layout_height="52dp"
                                android:layout_marginTop="8dp"
                                android:background="@drawable/bg_edittext"
                                android:hint="Bếp nhà B"
                                android:inputType="text"
                                android:paddingStart="16dp"
                                android:paddingEnd="16dp"
                                android:textColor="#222222"
                                android:textColorHint="#B8BDC9" />

                            <TextView
                                style="@style/LabelStyle"
                                android:layout_marginTop="18dp"
                                android:text="MÔ TẢ" />

                            <EditText
                                android:id="@+id/edtDescription"
                                android:layout_width="match_parent"
                                android:layout_height="52dp"
                                android:layout_marginTop="8dp"
                                android:background="@drawable/bg_edittext"
                                android:hint="Cơm trưa sinh viên"
                                android:inputType="text"
                                android:paddingStart="16dp"
                                android:paddingEnd="16dp"
                                android:textColor="#222222"
                                android:textColorHint="#B8BDC9" />

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="18dp"
                                android:orientation="horizontal">

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_marginEnd="8dp"
                                    android:layout_weight="1"
                                    android:orientation="vertical">

                                    <TextView
                                        style="@style/LabelStyle"
                                        android:text="GIỜ MỞ" />

                                    <EditText
                                        android:id="@+id/edtOpenTime"
                                        android:layout_width="match_parent"
                                        android:layout_height="52dp"
                                        android:layout_marginTop="8dp"
                                        android:background="@drawable/bg_edittext"
                                        android:hint="08:00"
                                        android:inputType="time"
                                        android:paddingStart="16dp"
                                        android:paddingEnd="16dp"
                                        android:textColor="#222222"
                                        android:textColorHint="#B8BDC9" />
                                </LinearLayout>

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="8dp"
                                    android:layout_weight="1"
                                    android:orientation="vertical">

                                    <TextView
                                        style="@style/LabelStyle"
                                        android:text="GIỜ ĐÓNG" />

                                    <EditText
                                        android:id="@+id/edtCloseTime"
                                        android:layout_width="match_parent"
                                        android:layout_height="52dp"
                                        android:layout_marginTop="8dp"
                                        android:background="@drawable/bg_edittext"
                                        android:hint="20:00"
                                        android:inputType="time"
                                        android:paddingStart="16dp"
                                        android:paddingEnd="16dp"
                                        android:textColor="#222222"
                                        android:textColorHint="#B8BDC9" />
                                </LinearLayout>
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/stepPassword"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <TextView
                            style="@style/LabelStyle"
                            android:text="MẬT KHẨU" />

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:layout_marginTop="8dp"
                            android:background="@drawable/bg_edittext">

                            <EditText
                                android:id="@+id/edtPassword"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@android:color/transparent"
                                android:hint="••••••••••••"
                                android:inputType="textPassword"
                                android:paddingStart="16dp"
                                android:paddingEnd="48dp"
                                android:textColor="#222222"
                                android:textColorHint="#B8BDC9" />

                            <ImageView
                                android:id="@+id/imgEyePassword"
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:layout_gravity="end|center_vertical"
                                android:layout_marginEnd="16dp"
                                android:contentDescription="Hiện mật khẩu"
                                android:src="@drawable/ic_eye"
                                app:tint="#A0A6B2" />
                        </FrameLayout>

                        <TextView
                            style="@style/LabelStyle"
                            android:layout_marginTop="18dp"
                            android:text="XÁC NHẬN MẬT KHẨU" />

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:layout_marginTop="8dp"
                            android:background="@drawable/bg_edittext">

                            <EditText
                                android:id="@+id/edtConfirmPassword"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@android:color/transparent"
                                android:hint="••••••••••••"
                                android:inputType="textPassword"
                                android:paddingStart="16dp"
                                android:paddingEnd="48dp"
                                android:textColor="#222222"
                                android:textColorHint="#B8BDC9" />

                            <ImageView
                                android:id="@+id/imgEyeConfirmPassword"
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:layout_gravity="end|center_vertical"
                                android:layout_marginEnd="16dp"
                                android:contentDescription="Hiện mật khẩu xác nhận"
                                android:src="@drawable/ic_eye"
                                app:tint="#A0A6B2" />
                        </FrameLayout>
                    </LinearLayout>
                </FrameLayout>
            </ScrollView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingBottom="20dp">

                <Button
                    android:id="@+id/btnStepBack"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_btn_gray"
                    android:text="Quay lại"
                    android:textAllCaps="false"
                    android:textColor="#1A1D26"
                    android:textStyle="bold"
                    android:visibility="gone" />

                <Button
                    android:id="@+id/btnStepNext"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:background="@drawable/home_bg_button_orange"
                    android:text="Tiếp tục"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/btnRegister"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:background="@drawable/home_bg_button_orange"
                    android:text="Đăng ký"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:visibility="gone" />
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>
