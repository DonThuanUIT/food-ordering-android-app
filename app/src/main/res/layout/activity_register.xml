<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/register"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    tools:context=".ui.auth.RegisterActivity">

    <!-- Nền trên -->
    <View
        android:id="@+id/topBackground"
        android:layout_width="0dp"
        android:layout_height="220dp"
        android:background="@drawable/home_bg_top_dark"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Nút back -->
    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="42dp"
        android:layout_height="42dp"
        android:layout_marginStart="20dp"
        android:layout_marginTop="36dp"
        android:background="@drawable/home_bg_circle_white"
        android:padding="10dp"
        android:scaleType="centerInside"
        android:src="@android:drawable/ic_media_previous"
        app:tint="#1D223D"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Title -->
    <TextView
        android:id="@+id/txtTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Đăng Ký Tài Khoản"
        android:textColor="#FFFFFF"
        android:textSize="28sp"
        android:textStyle="bold"
        android:fontFamily="sans-serif-medium"
        app:layout_constraintTop_toTopOf="@id/topBackground"
        app:layout_constraintBottom_toBottomOf="@id/topBackground"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="-20dp"/>

    <!-- Card trắng -->
    <androidx.cardview.widget.CardView
        android:id="@+id/registerCard"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="-20dp"
        android:layout_marginBottom="16dp"
        app:cardCornerRadius="28dp"
        app:cardElevation="8dp"
        app:layout_constraintTop_toBottomOf="@id/topBackground"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- ROLE SELECTION FIRST -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CHỌN VAI TRÒ"
                    android:textColor="#666666"
                    android:textStyle="bold"
                    android:textSize="12sp"/>

                <RadioGroup
                    android:id="@+id/rgRole"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_edittext"
                    android:orientation="horizontal"
                    android:padding="4dp">

                    <RadioButton
                        android:id="@+id/rbStudent"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@drawable/bg_radio_selector"
                        android:button="@null"
                        android:checked="true"
                        android:gravity="center"
                        android:text="Sinh viên"
                        android:textColor="#333333"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <RadioButton
                        android:id="@+id/rbOwner"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@drawable/bg_radio_selector"
                        android:button="@null"
                        android:gravity="center"
                        android:text="Chủ quán"
                        android:textColor="#333333"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </RadioGroup>

                <!-- COMMON FIELDS -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="HỌ VÀ TÊN"
                    android:textColor="#666666"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    android:layout_marginTop="18dp"/>

                <EditText
                    android:id="@+id/edtFullName"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_edittext"
                    android:hint="Nguyễn Văn A"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:inputType="textPersonName"
                    android:textColor="#222222"
                    android:textColorHint="#B8BDC9"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="EMAIL"
                    android:textColor="#666666"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    android:layout_marginTop="18dp"/>

                <EditText
                    android:id="@+id/edtEmail"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_edittext"
                    android:hint="example@gmail.com"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:inputType="textEmailAddress"
                    android:textColor="#222222"
                    android:textColorHint="#B8BDC9"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SỐ ĐIỆN THOẠI"
                    android:textColor="#666666"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    android:layout_marginTop="18dp"/>

                <EditText
                    android:id="@+id/edtPhone"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_edittext"
                    android:hint="0123456789"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:inputType="phone"
                    android:textColor="#222222"
                    android:textColorHint="#B8BDC9"/>

                <!-- STUDENT SPECIFIC -->
                <LinearLayout
                    android:id="@+id/layoutStudentFields"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="visible">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="MÃ TÒA NHÀ (BUILDING ID)"
                        android:textColor="#666666"
                        android:textStyle="bold"
                        android:textSize="12sp"
                        android:layout_marginTop="18dp"/>

                    <EditText
                        android:id="@+id/edtBuildingId"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_edittext"
                        android:hint="Nhập UUID tòa nhà"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:inputType="text"
                        android:textColor="#222222"
                        android:textColorHint="#B8BDC9"/>
                </LinearLayout>

                <!-- VENDOR SPECIFIC -->
                <LinearLayout
                    android:id="@+id/layoutVendorFields"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TÊN CỬA HÀNG"
                        android:textColor="#666666"
                        android:textStyle="bold"
                        android:textSize="12sp"
                        android:layout_marginTop="18dp"/>

                    <EditText
                        android:id="@+id/edtShopName"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_edittext"
                        android:hint="Bếp nhà B"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:inputType="text"
                        android:textColor="#222222"
                        android:textColorHint="#B8BDC9"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="MÔ TẢ"
                        android:textColor="#666666"
                        android:textStyle="bold"
                        android:textSize="12sp"
                        android:layout_marginTop="18dp"/>

                    <EditText
                        android:id="@+id/edtDescription"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_edittext"
                        android:hint="Cơm trưa sinh viên"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:inputType="text"
                        android:textColor="#222222"
                        android:textColorHint="#B8BDC9"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="18dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginEnd="8dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="GIỜ MỞ CỬA"
                                android:textColor="#666666"
                                android:textStyle="bold"
                                android:textSize="12sp"/>

                            <EditText
                                android:id="@+id/edtOpenTime"
                                android:layout_width="match_parent"
                                android:layout_height="52dp"
                                android:layout_marginTop="8dp"
                                android:background="@drawable/bg_edittext"
                                android:hint="08:00:00"
                                android:paddingStart="16dp"
                                android:paddingEnd="16dp"
                                android:inputType="time"
                                android:textColor="#222222"
                                android:textColorHint="#B8BDC9"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="8dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="GIỜ ĐÓNG CỬA"
                                android:textColor="#666666"
                                android:textStyle="bold"
                                android:textSize="12sp"/>

                            <EditText
                                android:id="@+id/edtCloseTime"
                                android:layout_width="match_parent"
                                android:layout_height="52dp"
                                android:layout_marginTop="8dp"
                                android:background="@drawable/bg_edittext"
                                android:hint="20:00:00"
                                android:paddingStart="16dp"
                                android:paddingEnd="16dp"
                                android:inputType="time"
                                android:textColor="#222222"
                                android:textColorHint="#B8BDC9"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <!-- PASSWORD -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MẬT KHẨU"
                    android:textColor="#666666"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    android:layout_marginTop="18dp"/>

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_edittext">

                    <EditText
                        android:id="@+id/edtPassword"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:hint="••••••••••••"
                        android:background="@android:color/transparent"
                        android:paddingStart="16dp"
                        android:paddingEnd="48dp"
                        android:inputType="textPassword"
                        android:textColor="#222222"
                        android:textColorHint="#B8BDC9"/>

                    <ImageView
                        android:id="@+id/imgEyePassword"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:layout_gravity="end|center_vertical"
                        android:layout_marginEnd="16dp"
                        android:src="@android:drawable/ic_menu_view"
                        app:tint="#A0A6B2"/>
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="XÁC NHẬN MẬT KHẨU"
                    android:textColor="#666666"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    android:layout_marginTop="18dp"/>

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_edittext">

                    <EditText
                        android:id="@+id/edtConfirmPassword"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:hint="••••••••••••"
                        android:background="@android:color/transparent"
                        android:paddingStart="16dp"
                        android:paddingEnd="48dp"
                        android:inputType="textPassword"
                        android:textColor="#222222"
                        android:textColorHint="#B8BDC9"/>

                    <ImageView
                        android:id="@+id/imgEyeConfirmPassword"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:layout_gravity="end|center_vertical"
                        android:layout_marginEnd="16dp"
                        android:src="@android:drawable/ic_menu_view"
                        app:tint="#A0A6B2"/>
                </FrameLayout>

                <!-- REGISTER BUTTON -->
                <Button
                    android:id="@+id/btnRegister"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="24dp"
                    android:layout_marginBottom="24dp"
                    android:background="@drawable/home_bg_button_orange"
                    android:text="ĐĂNG KÝ"
                    android:textAllCaps="true"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    app:backgroundTint="@null" />

            </LinearLayout>
        </ScrollView>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>
