<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/register"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    tools:context=".ui.auth.RegisterActivity">

    <!-- Nền trên -->
    <View
        android:id="@+id/topBackground"
        android:layout_width="0dp"
        android:layout_height="280dp"
        android:background="@drawable/bg_top_dark"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Nút back -->
    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="42dp"
        android:layout_height="42dp"
        android:layout_marginStart="20dp"
        android:layout_marginTop="36dp"
        android:background="@drawable/bg_circle_white"
        android:padding="10dp"
        android:scaleType="centerInside"
        android:src="@android:drawable/ic_media_previous"
        app:tint="#1D223D"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Title -->
    <TextView
        android:id="@+id/txtTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Đăng Ký Tài Khoản"
        android:textColor="#FFFFFF"
        android:textSize="30sp"
        android:textStyle="bold"
        android:fontFamily="sans-serif-medium"
        app:layout_constraintTop_toTopOf="@id/topBackground"
        app:layout_constraintBottom_toBottomOf="@id/topBackground"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="-30dp"/>

    <!-- Subtitle -->
    <TextView
        android:id="@+id/txtSubTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Hãy đăng ký để bắt đầu"
        android:textColor="#D6D6E0"
        android:textSize="14sp"
        app:layout_constraintTop_toBottomOf="@id/txtTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp"/>

    <!-- Card trắng -->
    <androidx.cardview.widget.CardView
        android:id="@+id/registerCard"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="-30dp"
        android:layout_marginBottom="16dp"
        app:cardCornerRadius="28dp"
        app:cardElevation="8dp"
        app:layout_constraintTop_toBottomOf="@id/topBackground"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- NAME -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TÊN ĐĂNG NHẬP"
                    android:textColor="#666666"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    android:layout_marginTop="8dp"/>

                <EditText
                    android:id="@+id/edtName"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_edittext"
                    android:hint="John doe"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:inputType="textPersonName"
                    android:textColor="#222222"
                    android:textColorHint="#B8BDC9"
                    android:backgroundTint="@null"/>

                <!-- EMAIL -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="EMAIL"
                    android:textColor="#666666"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    android:layout_marginTop="18dp"/>

                <EditText
                    android:id="@+id/edtEmail"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_edittext"
                    android:hint="example@gmail.com"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:inputType="textEmailAddress"
                    android:textColor="#222222"
                    android:textColorHint="#B8BDC9"
                    android:backgroundTint="@null"/>

                <!-- PASSWORD -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MẬT KHẨU"
                    android:textColor="#666666"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    android:layout_marginTop="18dp"/>

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_edittext">

                    <EditText
                        android:id="@+id/edtPassword"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:hint="••••••••••••"
                        android:background="@android:color/transparent"
                        android:paddingStart="16dp"
                        android:paddingEnd="48dp"
                        android:inputType="textPassword"
                        android:textColor="#222222"
                        android:textColorHint="#B8BDC9"/>

                    <ImageView
                        android:id="@+id/imgEyePassword"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:layout_gravity="end|center_vertical"
                        android:layout_marginEnd="16dp"
                        android:src="@android:drawable/ic_menu_view"
                        app:tint="#A0A6B2"/>
                </FrameLayout>

                <!-- RE-TYPE PASSWORD -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="XÁC NHẬN MẬT KHẨU"
                    android:textColor="#666666"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    android:layout_marginTop="18dp"/>

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_edittext">

                    <EditText
                        android:id="@+id/edtRePassword"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:hint="••••••••••••"
                        android:background="@android:color/transparent"
                        android:paddingStart="16dp"
                        android:paddingEnd="48dp"
                        android:inputType="textPassword"
                        android:textColor="#222222"
                        android:textColorHint="#B8BDC9"/>

                    <ImageView
                        android:id="@+id/imgEyeRePassword"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:layout_gravity="end|center_vertical"
                        android:layout_marginEnd="16dp"
                        android:src="@android:drawable/ic_menu_view"
                        app:tint="#A0A6B2"/>
                </FrameLayout>

                <!-- ROLE -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CHỌN VAI TRÒ"
                    android:textColor="#666666"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    android:layout_marginTop="18dp"/>

                <RadioGroup
                    android:id="@+id/rgRole"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_edittext"
                    android:orientation="horizontal"
                    android:padding="4dp">

                    <RadioButton
                        android:id="@+id/rbStudent"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@drawable/bg_radio_selector"
                        android:button="@null"
                        android:checked="true"
                        android:gravity="center"
                        android:text="Sinh viên"
                        android:textColor="#333333"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <RadioButton
                        android:id="@+id/rbOwner"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@drawable/bg_radio_selector"
                        android:button="@null"
                        android:gravity="center"
                        android:text="Chủ quán"
                        android:textColor="#333333"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </RadioGroup>

                <!-- SIGN UP BUTTON -->
                <Button
                    android:id="@+id/btnSignUp"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="24dp"
                    android:layout_marginBottom="8dp"
                    android:text="ĐĂNG KÝ"
                    android:textAllCaps="true"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:background="@drawable/bg_button_orange"
                    app:backgroundTint="@null"/>

            </LinearLayout>
        </ScrollView>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>