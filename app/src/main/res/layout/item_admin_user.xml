<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingVertical="16dp">

    <ImageView
        android:id="@+id/ivAdminUserAvatar"
        android:layout_width="58dp"
        android:layout_height="58dp"
        android:background="@drawable/bg_admin_avatar"
        android:padding="12dp"
        android:scaleType="centerInside"
        android:src="@drawable/ic_profile" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvAdminUserName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/vendor_dark_text_primary"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvAdminUserEmail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/vendor_dark_text_secondary"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/tvAdminUserRole"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:paddingHorizontal="12dp"
            android:paddingVertical="4dp"
            android:textColor="@color/vendor_dark_text_secondary"
            android:textSize="12sp" />
    </LinearLayout>

    <Switch
        android:id="@+id/swAdminUserActive"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:thumbTint="@color/white"
        android:trackTint="@color/brand_orange" />
</LinearLayout>
