<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F7F9FA">

    <!-- Header Toolbar -->
    <LinearLayout
        android:id="@+id/layout_ai_header"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="#FF7A21"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:elevation="4dp">

        <ImageView
            android:id="@+id/btn_back_ai"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_arrow_back_clean"
            android:clickable="true"
            android:focusable="true"
            android:padding="4dp"
            app:tint="@android:color/white" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="16dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Trợ lý Ẩm thực AI ✨"
                android:textColor="@android:color/white"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Gợi ý món ngon từ Gemini"
                android:textColor="#EFEFEF"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Chat Messages View -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_ai_chat_messages"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/layout_ai_input_container"
        android:layout_below="@id/layout_ai_header"
        android:clipToPadding="false"
        android:padding="16dp"
        android:scrollbarStyle="outsideOverlay" />

    <!-- Empty/Intro View -->
    <LinearLayout
        android:id="@+id/layout_ai_intro"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🤖"
            android:textSize="64sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Hỏi tôi bất cứ thứ gì!"
            android:textColor="#333333"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:text="Ví dụ: 'Tôi muốn ăn món nước chuẩn vị miền Trung và cay nhiều' hoặc 'Tìm món cơm bình dân cho buổi trưa'"
            android:textColor="#666666"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- Progress Indicator -->
    <ProgressBar
        android:id="@+id/progress_ai_loading"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_above="@id/layout_ai_input_container"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="16dp"
        android:visibility="gone" />

    <!-- Chat Input Container -->
    <LinearLayout
        android:id="@+id/layout_ai_input_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="@android:color/white"
        android:elevation="8dp"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingVertical="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/et_ai_input"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/bg_chat_input"
                android:hint="Nhập yêu cầu của bạn..."
                android:imeOptions="actionSend"
                android:inputType="textLongMessage"
                android:maxLines="4"
                android:minHeight="48dp"
                android:paddingHorizontal="16dp"
                android:paddingVertical="10dp"
                android:textColor="#333333"
                android:textSize="15sp" />

            <ImageButton
                android:id="@+id/btn_send_ai"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_chat_send"
                android:src="@drawable/ic_arrow_forward"
                app:tint="@android:color/white" />
        </LinearLayout>
    </LinearLayout>

</RelativeLayout>

