<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@color/vendor_dark_card"
    app:cardUseCompatPadding="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header Row (ID, Status, Time) -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp">

            <TextView
                android:id="@+id/tv_order_id"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:text="Đơn hàng #..."
                android:textColor="@color/vendor_dark_text_primary"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_order_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_toStartOf="@id/tv_order_time"
                android:layout_marginEnd="12dp"
                android:background="@drawable/bg_badge_orange"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                android:text="PENDING"
                android:textColor="@color/white"
                android:textSize="10sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_order_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:text="12:45"
                android:textColor="@color/vendor_dark_text_secondary"
                android:textSize="12sp" />
        </RelativeLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:background="@color/vendor_dark_divider"
            android:layout_marginBottom="10dp"/>

        <!-- Delivery Info -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/tv_order_room"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Phòng..."
                android:textColor="@color/vendor_dark_text_primary"
                android:textSize="18sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tv_order_delivery"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Giao đến: ..."
                android:textColor="@color/vendor_dark_text_secondary"
                android:textSize="13sp"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <!-- Customer Info -->
        <TextView
            android:id="@+id/tv_order_customer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Khách: ..."
            android:textColor="@color/vendor_dark_text_secondary"
            android:textSize="12sp"
            android:layout_marginBottom="10dp"/>

        <!-- Items Container -->
        <LinearLayout
            android:id="@+id/layout_order_items"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/vendor_dark_bg"
            android:padding="12dp"
            android:layout_marginBottom="12dp"/>

        <!-- Total Price & Cancel Reason -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:text="Tổng thanh toán"
                android:textColor="@color/vendor_dark_text_primary"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tv_order_total"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:text="0đ"
                android:textColor="@color/vendor_dark_orange"
                android:textSize="18sp"
                android:textStyle="bold" />
        </RelativeLayout>

        <!-- Cancel Reason (Visible only when status is CANCELLED) -->
        <TextView
            android:id="@+id/tv_cancel_reason"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#2C1A1A"
            android:padding="8dp"
            android:textColor="@color/status_red"
            android:textSize="12sp"
            android:textStyle="italic"
            android:text="Lý do hủy: ..."
            android:layout_marginBottom="10dp"
            android:visibility="gone"/>

        <!-- Action Buttons Row -->
        <LinearLayout
            android:id="@+id/layout_actions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end"
            android:layout_marginTop="4dp">

            <!-- Cancel Button -->
            <Button
                android:id="@+id/btn_action_cancel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hủy đơn"
                android:textColor="@color/vendor_dark_text_secondary"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                app:strokeColor="@color/vendor_dark_border"
                app:cornerRadius="8dp"
                android:layout_marginEnd="8dp"/>

            <!-- Next State Buttons -->
            <Button
                android:id="@+id/btn_action_accept"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Xác nhận"
                android:backgroundTint="@color/button_green"
                android:textColor="@color/white"
                app:cornerRadius="8dp"
                android:visibility="gone"/>

            <Button
                android:id="@+id/btn_action_deliver"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Giao hàng"
                android:backgroundTint="@color/vendor_dark_orange"
                android:textColor="@color/white"
                app:cornerRadius="8dp"
                android:visibility="gone"/>

            <Button
                android:id="@+id/btn_action_complete"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hoàn thành"
                android:backgroundTint="@color/status_success"
                android:textColor="@color/white"
                app:cornerRadius="8dp"
                android:visibility="gone"/>

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>
