<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="9dp"
    android:layout_marginBottom="10dp"
    app:cardBackgroundColor="#FFFFFF"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="136dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingTop="16dp"
        android:paddingEnd="18dp"
        android:paddingBottom="16dp">

        <ImageView
            android:id="@+id/ivMenuFoodImage"
            android:layout_width="122dp"
            android:layout_height="104dp"
            android:background="#F3F4F6"
            android:scaleType="centerCrop"
            android:src="@drawable/logo_food" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="24dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvMenuFoodName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="Cơm Tấm Sườn Nướng"
                android:textColor="#05070B"
                android:textSize="21sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvMenuFoodDescription"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="8dp"
                android:layout_weight="1"
                android:ellipsize="end"
                android:lineSpacingExtra="2dp"
                android:maxLines="2"
                android:text="Cơm tấm dẻo, sườn nướng mỡ hành đậm vị."
                android:textColor="#5B3A2E"
                android:textSize="17sp" />

            <TextView
                android:id="@+id/tvMenuFoodPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="35.000đ"
                android:textColor="#05070B"
                android:textSize="22sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/btnAddFood"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_marginStart="14dp"
            android:background="@drawable/bg_shop_menu_plus"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:includeFontPadding="false"
            android:text="+"
            android:textColor="#FFFFFF"
            android:textSize="28sp" />
    </LinearLayout>
</androidx.cardview.widget.CardView>
