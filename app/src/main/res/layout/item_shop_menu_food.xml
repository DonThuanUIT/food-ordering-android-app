<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="9dp"
    android:layout_marginBottom="10dp"
    app:cardBackgroundColor="@color/vendor_dark_card"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="112dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingTop="12dp"
        android:paddingEnd="12dp"
        android:paddingBottom="12dp">

        <RelativeLayout
            android:layout_width="78dp"
            android:layout_height="78dp">

            <ImageView
                android:id="@+id/ivMenuFoodImage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@color/vendor_dark_bg"
                android:scaleType="centerCrop"
                android:src="@drawable/logo_food" />

            <!-- Badge Overlay (Popular / Bestseller) -->
            <TextView
                android:id="@+id/tv_badge_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_alignParentTop="true"
                android:layout_margin="4dp"
                android:paddingHorizontal="6dp"
                android:paddingVertical="2dp"
                android:background="@drawable/bg_badge_orange"
                android:text="Popular"
                android:textColor="@android:color/white"
                android:textSize="8sp"
                android:textStyle="bold"
                android:visibility="gone"/>
        </RelativeLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvMenuFoodName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="Cơm Tấm Sườn Nướng"
                android:textColor="@color/vendor_dark_text_primary"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvMenuFoodDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="Cơm tấm dẻo, sườn nướng mỡ hành đậm vị."
                android:textColor="@color/vendor_dark_text_secondary"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tvMenuFoodRating"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="★ N/A"
                android:textColor="#FF9800"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvMenuFoodPrice"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:ellipsize="end"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:text="35.000đ"
                android:textColor="@color/vendor_dark_text_primary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvMenuFoodTags"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/vendor_dark_text_secondary"
                android:textSize="10sp"
                android:ellipsize="end"
                android:maxLines="1"
                android:visibility="gone" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/btnAddFood"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_shop_menu_plus"
            android:clickable="true"
            android:contentDescription="Thêm món"
            android:focusable="true"
            android:padding="12dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_plus_white"
            app:tint="@android:color/white" />
    </LinearLayout>
</androidx.cardview.widget.CardView>
