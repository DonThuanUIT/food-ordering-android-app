<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_profile_container"
    android:orientation="vertical"
    android:padding="22dp">

    <View
        android:layout_width="56dp"
        android:layout_height="6dp"
        android:layout_gravity="center_horizontal"
        android:background="@drawable/bg_admin_handle" />

    <TextView
        android:id="@+id/tvReviewsTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:text="Danh gia cua toi"
        android:textColor="@color/text_primary"
        android:textSize="22sp"
        android:textStyle="bold" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvStudentReviews"
        android:layout_width="match_parent"
        android:layout_height="360dp"
        android:layout_marginTop="14dp" />

    <TextView
        android:id="@+id/tvStudentReviewsEmpty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:paddingVertical="28dp"
        android:text="Dang tai danh gia..."
        android:textColor="@color/text_secondary"
        android:textSize="14sp" />
</LinearLayout>
