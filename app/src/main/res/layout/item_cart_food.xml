<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cvItemImg"
        android:layout_width="72dp"
        android:layout_height="72dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:strokeWidth="0dp">

        <ImageView
            android:id="@+id/ivCartFoodImage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@drawable/logo_food" />
    </com.google.android.material.card.MaterialCardView>

    <LinearLayout
        android:id="@+id/layoutCartFoodInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="12dp"
        android:layout_toEndOf="@id/cvItemImg"
        android:layout_toStartOf="@id/layoutCartItemActions"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvCartFoodName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="2"
            android:text="Tên món"
            android:textColor="@color/vendor_dark_text_primary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvCartFoodPrice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="0đ"
            android:textColor="#FF7A21"
            android:textSize="16sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layoutCartItemActions"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_centerVertical="true"
        android:gravity="end"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/btnDeleteCartItem"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_gravity="end"
            android:contentDescription="Delete item"
            android:padding="4dp"
            android:src="@drawable/ic_delete_outline"
            app:tint="#E53935" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_search_white"
            android:backgroundTint="@color/vendor_dark_bg"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingHorizontal="8dp">

        <ImageButton
            android:id="@+id/btnMinus"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Giảm số lượng"
            android:padding="5dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_minus" />

        <TextView
            android:id="@+id/tvCartQuantity"
            android:layout_width="32dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="1"
            android:textColor="@color/vendor_dark_text_primary"
            android:textSize="15sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/btnPlus"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:background="@drawable/home_bg_button_orange"
            android:contentDescription="Tăng số lượng"
            android:padding="5dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_plus_white" />
        </LinearLayout>
    </LinearLayout>
</RelativeLayout>
