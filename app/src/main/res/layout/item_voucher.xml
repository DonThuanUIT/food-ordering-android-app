<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="14dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="3dp"
    app:cardPreventCornerOverlap="true"
    app:cardBackgroundColor="@color/vendor_dark_card">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:baselineAligned="false">

        <!-- Left Portion (Coupon Badge) -->
        <LinearLayout
            android:id="@+id/layout_left_portion"
            android:layout_width="100dp"
            android:layout_height="match_parent"
            android:background="@color/vendor_dark_orange"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="8dp">

            <TextView
                android:id="@+id/tv_discount_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="10%"
                android:textColor="@color/white"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_discount_type_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="GIẢM"
                android:textColor="#FFE0CC"
                android:textSize="10sp"
                android:textStyle="bold"
                android:layout_marginTop="2dp" />

            <View
                android:layout_width="40dp"
                android:layout_height="1dp"
                android:background="#FFE0CC"
                android:layout_marginVertical="6dp"/>

            <TextView
                android:id="@+id/tv_voucher_code"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SUMMER10"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:textStyle="bold"
                android:ellipsize="end"
                android:maxLines="1"/>

        </LinearLayout>

        <!-- Right Portion (Details) -->
        <RelativeLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@color/vendor_dark_card"
            android:padding="12dp">

            <!-- Title & Status Switch -->
            <TextView
                android:id="@+id/tv_voucher_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_toStartOf="@id/switch_active"
                android:layout_marginEnd="8dp"
                android:text="Giảm giá chào hè cực đã"
                android:textColor="@color/vendor_dark_text_primary"
                android:textSize="15sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"/>

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switch_active"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_alignParentTop="true"
                android:theme="@style/Theme.FoodOrderingApp"
                app:thumbTint="@color/vendor_dark_orange"
                app:trackTint="#FFCCBC"
                android:minHeight="48dp"
                android:minWidth="48dp"
                android:padding="8dp"/>

            <!-- Usage Date -->
            <TextView
                android:id="@+id/tv_voucher_dates"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@id/tv_voucher_title"
                android:layout_marginTop="4dp"
                android:text="Hạn dùng: 18/06 - 25/06"
                android:textColor="@color/vendor_dark_text_secondary"
                android:textSize="11sp"/>

            <!-- Condition Details -->
            <TextView
                android:id="@+id/tv_voucher_conditions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@id/tv_voucher_dates"
                android:layout_marginTop="4dp"
                android:text="Đơn hàng từ: 50,000đ • Giảm tối đa: 20,000đ"
                android:textColor="@color/vendor_dark_text_secondary"
                android:textSize="11sp"/>

            <!-- Application Type Target -->
            <TextView
                android:id="@+id/tv_voucher_apply_type"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@id/tv_voucher_conditions"
                android:layout_marginTop="4dp"
                android:text="Áp dụng cho: Món ăn cụ thể (3 món)"
                android:textColor="@color/vendor_dark_orange"
                android:textSize="11sp"
                android:textStyle="bold"/>

            <!-- Divider -->
            <View
                android:id="@+id/divider_actions"
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:background="@color/vendor_dark_divider"
                android:layout_below="@id/tv_voucher_apply_type"
                android:layout_marginVertical="8dp"/>

            <!-- Actions Row -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/divider_actions"
                android:layout_alignParentEnd="true"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <!-- Edit Button -->
                <LinearLayout
                    android:id="@+id/btn_edit"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="14dp"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@android:drawable/ic_menu_edit"
                        app:tint="@color/vendor_dark_orange"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:text="Sửa"
                        android:textColor="@color/vendor_dark_orange"
                        android:textSize="12sp"
                        android:textStyle="bold"/>
                </LinearLayout>

                <!-- Space -->
                <View
                    android:layout_width="16dp"
                    android:layout_height="1dp"/>

                <!-- Delete Button -->
                <LinearLayout
                    android:id="@+id/btn_delete"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="14dp"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/ic_delete_outline"
                        app:tint="@color/status_red"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:text="Xóa"
                        android:textColor="@color/status_red"
                        android:textSize="12sp"
                        android:textStyle="bold"/>
                </LinearLayout>

            </LinearLayout>

        </RelativeLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>
