<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/vendor_dark_bg">

    <!-- Header Section -->
    <RelativeLayout
        android:id="@+id/layout_header"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="@color/vendor_dark_bg"
        android:elevation="4dp"
        android:paddingHorizontal="16dp">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_centerVertical="true"
            android:layout_alignParentStart="true"
            android:src="@drawable/ic_back"
            android:padding="12dp"
            android:contentDescription="Quay lại"
            app:tint="@color/vendor_dark_text_primary"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"/>

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Tạo Voucher Mới"
            android:textColor="@color/vendor_dark_text_primary"
            android:textSize="18sp"
            android:textStyle="bold" />

    </RelativeLayout>

    <!-- Scrollable Form Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/layout_header"
        android:layout_above="@id/btn_save_voucher"
        android:fillViewport="true"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Card for General Info -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardElevation="3dp"
                android:layout_marginBottom="16dp"
                app:cardUseCompatPadding="true"
                app:cardBackgroundColor="@color/vendor_dark_card">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Thông tin chung"
                        android:textColor="@color/vendor_dark_text_primary"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp"/>

                    <!-- Voucher Code Input -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Mã Voucher (*)"
                        android:textColor="#8A7D79"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="6dp"/>
                    <EditText
                        android:id="@+id/et_code"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:hint="Ví dụ: SUMMER50 (viết hoa, không cách)"
                        android:inputType="textCapCharacters"
                        android:digits="ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789"
                        android:background="@drawable/bg_vendor_input_dark"
                        android:textColor="@color/vendor_dark_text_primary"
                        android:textColorHint="#8A7D79"
                        android:paddingHorizontal="12dp"
                        android:textSize="14sp"
                        android:layout_marginBottom="16dp"
                        android:maxLines="1"/>

                    <!-- Title Input -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tiêu đề hiển thị (*)"
                        android:textColor="#8A7D79"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="6dp"/>
                    <EditText
                        android:id="@+id/et_title"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:hint="Ví dụ: Khuyến mãi mừng hè"
                        android:inputType="text"
                        android:background="@drawable/bg_vendor_input_dark"
                        android:textColor="@color/vendor_dark_text_primary"
                        android:textColorHint="#8A7D79"
                        android:paddingHorizontal="12dp"
                        android:textSize="14sp"
                        android:layout_marginBottom="8dp"
                        android:maxLines="1"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Card for Discount Rules -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardElevation="3dp"
                android:layout_marginBottom="16dp"
                app:cardUseCompatPadding="true"
                app:cardBackgroundColor="@color/vendor_dark_card">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Thiết lập giảm giá"
                        android:textColor="@color/vendor_dark_text_primary"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp"/>

                    <!-- Discount Type Radio Group -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Loại giảm giá (*)"
                        android:textColor="#8A7D79"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="6dp"/>
                    <RadioGroup
                        android:id="@+id/rg_discount_type"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="16dp">
                        <RadioButton
                            android:id="@+id/rb_percentage"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Theo phần trăm (%)"
                            android:textSize="13sp"
                            android:textColor="@color/vendor_dark_text_primary"
                            android:buttonTint="@color/vendor_dark_orange"
                            android:checked="true"/>
                        <RadioButton
                            android:id="@+id/rb_fixed_amount"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Số tiền cố định (đ)"
                            android:textSize="13sp"
                            android:textColor="@color/vendor_dark_text_primary"
                            android:buttonTint="@color/vendor_dark_orange"/>
                    </RadioGroup>

                    <!-- Discount Value Input -->
                    <TextView
                        android:id="@+id/tv_discount_value_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Giá trị giảm giá (*)"
                        android:textColor="#8A7D79"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="6dp"/>
                    <EditText
                        android:id="@+id/et_discount_value"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:hint="Ví dụ: 10 (cho 10%) hoặc 20000"
                        android:inputType="number"
                        android:background="@drawable/bg_vendor_input_dark"
                        android:textColor="@color/vendor_dark_text_primary"
                        android:textColorHint="#8A7D79"
                        android:paddingHorizontal="12dp"
                        android:textSize="14sp"
                        android:layout_marginBottom="16dp"
                        android:maxLines="1"/>

                    <!-- Min Order Value Input -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Giá trị đơn hàng tối thiểu"
                        android:textColor="#8A7D79"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="6dp"/>
                    <EditText
                        android:id="@+id/et_min_order"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:hint="Ví dụ: 50000 (để trống nếu bằng 0)"
                        android:inputType="number"
                        android:background="@drawable/bg_vendor_input_dark"
                        android:textColor="@color/vendor_dark_text_primary"
                        android:textColorHint="#8A7D79"
                        android:paddingHorizontal="12dp"
                        android:textSize="14sp"
                        android:layout_marginBottom="16dp"
                        android:maxLines="1"/>

                    <!-- Max Discount Value Input -->
                    <LinearLayout
                        android:id="@+id/layout_max_discount"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Mức giảm tối đa"
                            android:textColor="#8A7D79"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="6dp"/>
                        <EditText
                            android:id="@+id/et_max_discount"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:hint="Ví dụ: 30000 (để trống nếu không giới hạn)"
                            android:inputType="number"
                            android:background="@drawable/bg_vendor_input_dark"
                            android:textColor="@color/vendor_dark_text_primary"
                            android:textColorHint="#8A7D79"
                            android:paddingHorizontal="12dp"
                            android:textSize="14sp"
                            android:layout_marginBottom="8dp"
                            android:maxLines="1"/>
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Card for Validity Period -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardElevation="3dp"
                android:layout_marginBottom="16dp"
                app:cardUseCompatPadding="true"
                app:cardBackgroundColor="@color/vendor_dark_card">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Thời gian hiệu lực"
                        android:textColor="@color/vendor_dark_text_primary"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp"/>

                    <!-- Start Date Picker Row -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ngày bắt đầu (*)"
                        android:textColor="#8A7D79"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="6dp"/>
                    <LinearLayout
                        android:id="@+id/btn_pick_start"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_vendor_input_dark"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="12dp"
                        android:layout_marginBottom="16dp"
                        android:clickable="true"
                        android:focusable="true">
                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_clock"
                            app:tint="#8A7D79"/>
                        <TextView
                            android:id="@+id/tv_start_date"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="10dp"
                            android:text="Chọn thời gian bắt đầu"
                            android:textColor="@color/vendor_dark_text_secondary"
                            android:textSize="14sp"/>
                    </LinearLayout>

                    <!-- End Date Picker Row -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ngày kết thúc (*)"
                        android:textColor="#8A7D79"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="6dp"/>
                    <LinearLayout
                        android:id="@+id/btn_pick_end"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_vendor_input_dark"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="12dp"
                        android:layout_marginBottom="8dp"
                        android:clickable="true"
                        android:focusable="true">
                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_clock"
                            app:tint="#8A7D79"/>
                        <TextView
                            android:id="@+id/tv_end_date"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="10dp"
                            android:text="Chọn thời gian kết thúc"
                            android:textColor="@color/vendor_dark_text_secondary"
                            android:textSize="14sp"/>
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Card for Applicability (Foods Selector) -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardElevation="3dp"
                android:layout_marginBottom="16dp"
                app:cardUseCompatPadding="true"
                app:cardBackgroundColor="@color/vendor_dark_card">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Phạm vi áp dụng"
                        android:textColor="@color/vendor_dark_text_primary"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp"/>

                    <!-- Apply Type Radio Group -->
                    <RadioGroup
                        android:id="@+id/rg_apply_type"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="16dp">
                        <RadioButton
                            android:id="@+id/rb_all_menu"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Toàn bộ menu"
                            android:textSize="13sp"
                            android:textColor="@color/vendor_dark_text_primary"
                            android:buttonTint="@color/vendor_dark_orange"
                            android:checked="true"/>
                        <RadioButton
                            android:id="@+id/rb_specific_foods"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Món ăn cụ thể"
                            android:textSize="13sp"
                            android:textColor="@color/vendor_dark_text_primary"
                            android:buttonTint="@color/vendor_dark_orange"/>
                    </RadioGroup>

                    <!-- Food Selection Section (Collapsible) -->
                    <LinearLayout
                        android:id="@+id/layout_foods_selector"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <Button
                            android:id="@+id/btn_select_foods"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Chọn món ăn..."
                            android:textColor="@color/white"
                            android:backgroundTint="@color/vendor_dark_orange"
                            android:textSize="12sp"
                            android:paddingHorizontal="16dp"
                            android:layout_marginBottom="8dp"/>

                        <TextView
                            android:id="@+id/tv_selected_foods_count"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Chưa chọn món nào"
                            android:textColor="@color/vendor_dark_orange"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="8dp"/>

                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Card for Activation Status -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardElevation="3dp"
                android:layout_marginBottom="16dp"
                app:cardUseCompatPadding="true"
                app:cardBackgroundColor="@color/vendor_dark_card">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Kích hoạt mã giảm giá"
                        android:textColor="@color/vendor_dark_text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_alignParentStart="true"
                        android:layout_centerVertical="true"/>

                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/switch_active_form"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:checked="true"
                        android:theme="@style/Theme.FoodOrderingApp"
                        app:thumbTint="@color/vendor_dark_orange"
                        app:trackTint="#FFCCBC"/>

                </RelativeLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

    <!-- Save Button -->
    <Button
        android:id="@+id/btn_save_voucher"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_alignParentBottom="true"
        android:layout_margin="16dp"
        android:text="LƯU VOUCHER"
        android:textSize="15sp"
        android:textStyle="bold"
        android:textColor="@color/white"
        android:backgroundTint="@color/vendor_dark_orange"
        app:cornerRadius="12dp"/>

</RelativeLayout>
