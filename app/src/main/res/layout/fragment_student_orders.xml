<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F6F7F9">

    <View
        android:layout_width="match_parent"
        android:layout_height="126dp"
        android:background="@drawable/home_bg_top_dark" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingTop="28dp"
        android:paddingBottom="96dp">

        <LinearLayout
            android:id="@+id/orderContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:background="@drawable/bg_order_card"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="22dp"
            android:paddingBottom="24dp">

            <TextView
                android:id="@+id/tvEmptyOrders"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:gravity="center"
                android:text="B&#7841;n ch&#432;a c&#243; &#273;&#417;n h&#224;ng &#273;ang ho&#7841;t &#273;&#7897;ng"
                android:textColor="#4D587A"
                android:textSize="16sp"
                android:visibility="gone" />

            <FrameLayout
                android:id="@+id/orderImageContainer"
                android:layout_width="match_parent"
                android:layout_height="170dp"
                android:background="@drawable/bg_order_inner_card"
                android:padding="18dp">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:adjustViewBounds="true"
                    android:scaleType="centerInside"
                    android:src="@drawable/logo_food" />
            </FrameLayout>

            <LinearLayout
                android:id="@+id/timelineContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="34dp"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="42dp"
                    android:layout_height="258dp"
                    android:gravity="center_horizontal"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/dotPending"
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:background="@drawable/bg_status_dot_done"
                        android:gravity="center"
                        android:text="1"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <View
                        android:layout_width="2dp"
                        android:layout_height="42dp"
                        android:background="@drawable/bg_status_line" />

                    <TextView
                        android:id="@+id/dotConfirmed"
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:background="@drawable/bg_status_dot_done"
                        android:gravity="center"
                        android:text="2"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <View
                        android:layout_width="2dp"
                        android:layout_height="42dp"
                        android:background="@drawable/bg_status_line" />

                    <TextView
                        android:id="@+id/dotDelivering"
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:background="@drawable/bg_status_dot_done"
                        android:gravity="center"
                        android:text="3"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <View
                        android:layout_width="2dp"
                        android:layout_height="42dp"
                        android:background="@drawable/bg_status_line" />

                    <TextView
                        android:id="@+id/dotCompleted"
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:background="@drawable/bg_status_dot_current"
                        android:gravity="center"
                        android:text="4"
                        android:textColor="#A13A00"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvPendingLabel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Ch&#7901; x&#225;c nh&#7853;n"
                        android:textColor="#111111"
                        android:textSize="19sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvPendingSub"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="&#272;&#417;n h&#224;ng &#273;&#227; &#273;&#432;&#7907;c t&#7841;o"
                        android:textColor="#4D587A"
                        android:textSize="15sp" />

                    <TextView
                        android:id="@+id/tvConfirmedLabel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="28dp"
                        android:text="&#272;&#227; x&#225;c nh&#7853;n"
                        android:textColor="#111111"
                        android:textSize="19sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvConfirmedTime"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:textColor="#3F4B6E"
                        android:textSize="16sp" />

                    <TextView
                        android:id="@+id/tvDeliveringLabel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="31dp"
                        android:text="&#272;ang giao h&#224;ng"
                        android:textColor="#111111"
                        android:textSize="19sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvDeliveringSub"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="&#272;&#417;n &#273;ang tr&#234;n &#273;&#432;&#7901;ng giao"
                        android:textColor="#4D587A"
                        android:textSize="15sp" />

                    <TextView
                        android:id="@+id/tvCompletedLabel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="31dp"
                        android:text="&#272;&#227; ho&#224;n th&#224;nh"
                        android:textColor="#111111"
                        android:textSize="19sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvCompletedSub"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Ch&#432;a c&#243; th&#7901;i gian c&#7853;p nh&#7853;t"
                        android:textColor="#4D587A"
                        android:textSize="15sp" />
                </LinearLayout>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="24dp"
                android:background="#DDDDDD" />

            <LinearLayout
                android:id="@+id/shopCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="30dp"
                android:background="@drawable/bg_order_inner_card"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:background="@drawable/bg_shop_logo_circle"
                        android:padding="10dp"
                        android:src="@drawable/logo_food" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvShopName"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="#111111"
                            android:textSize="20sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvOrderNumber"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="5dp"
                            android:textColor="#4D587A"
                            android:textSize="16sp" />
                    </LinearLayout>
                </LinearLayout>

                <TextView
                    android:id="@+id/tvOrderAddress"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:textColor="#4D587A"
                    android:textSize="15sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/summaryCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:background="@drawable/bg_order_inner_card"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Order Summary"
                    android:textColor="#111111"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:id="@+id/orderItemsContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:orientation="vertical" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="22dp"
                    android:background="#D7D7D7" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Total"
                        android:textColor="#111111"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvOrderTotal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#A13A00"
                        android:textSize="24sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</FrameLayout>
