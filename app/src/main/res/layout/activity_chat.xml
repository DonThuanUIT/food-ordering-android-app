<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_page"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="88dp"
        android:background="@color/profile_header_dark"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingTop="20dp">

        <ImageButton
            android:id="@+id/btnBackChat"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/home_bg_circle_white"
            android:contentDescription="Quay lại"
            android:padding="11dp"
            android:src="@drawable/ic_arrow_back_clean"
            app:tint="@color/profile_header_dark" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvChatTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="Tin nhắn"
                android:textColor="@color/white"
                android:textSize="19sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvChatSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="Nhắn tin trực tiếp"
                android:textColor="#D8DCEE"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvChatMessages"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingTop="14dp"
            android:paddingBottom="14dp" />

        <TextView
            android:id="@+id/tvChatEmpty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:paddingHorizontal="32dp"
            android:text="Gửi tin nhắn đầu tiên để bắt đầu trao đổi."
            android:textColor="@color/text_secondary"
            android:textSize="15sp" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/vendor_header_bg"
        android:elevation="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingVertical="10dp">

        <EditText
            android:id="@+id/edtChatMessage"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:minHeight="44dp"
            android:layout_weight="1"
            android:background="@drawable/bg_chat_input"
            android:hint="Nhập tin nhắn..."
            android:imeOptions="actionSend"
            android:inputType="textCapSentences|textMultiLine"
            android:maxLines="5"
            android:paddingHorizontal="16dp"
            android:paddingVertical="10dp"
            android:textColor="@color/vendor_dark_text_primary"
            android:textColorHint="@color/vendor_dark_text_secondary"
            android:textSize="15sp" />

        <ImageButton
            android:id="@+id/btnSendChat"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginStart="12dp"
            android:background="@drawable/bg_chat_send"
            android:contentDescription="Gửi tin nhắn"
            android:padding="11dp"
            android:src="@drawable/ic_arrow_forward"
            app:tint="@color/white" />
    </LinearLayout>
</LinearLayout>
