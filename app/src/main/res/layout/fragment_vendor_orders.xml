<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F8F8">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:text="Order Management"
            android:textSize="28sp"
            android:textStyle="bold"/>

        <TextView
            android:text="Managing 12 active orders"
            android:textColor="#8E8E93"
            android:layout_marginBottom="20dp"/>

        <!-- Tabs -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="3">

            <Button
                android:layout_weight="1"
                android:text="Pending"/>

            <Button
                android:layout_weight="1"
                android:text="Preparing"/>

            <Button
                android:layout_weight="1"
                android:text="Delivered"/>
        </LinearLayout>

        <!-- Order card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            app:cardCornerRadius="16dp">

            <LinearLayout
                android:padding="16dp"
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:text="Alex Rivers"
                    android:textStyle="bold"
                    android:textSize="22sp"/>

                <TextView
                    android:text="Tower B, Room 402"/>

                <TextView
                    android:text="2x Spicy Zinger Burger"/>

                <TextView
                    android:text="1x Coke Zero"/>

                <Button
                    android:text="Confirm Order"
                    android:layout_marginTop="12dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Rush hour -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            app:cardCornerRadius="16dp"
            android:backgroundTint="#8B5A00">

            <LinearLayout
                android:padding="16dp"
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:text="Rush Hour!"
                    android:textColor="#FFFFFF"
                    android:textSize="22sp"
                    android:textStyle="bold"/>

                <TextView
                    android:text="Volume is 25% higher"
                    android:textColor="#FFFFFF"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>