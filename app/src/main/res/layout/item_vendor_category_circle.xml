<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="90dp"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:paddingTop="6dp"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:clickable="true"
    android:focusable="true"
    android:background="?attr/selectableItemBackgroundBorderless">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_emoji_container"
        android:layout_width="56dp"
        android:layout_height="56dp"
        app:cardCornerRadius="28dp"
        app:cardElevation="3dp"
        app:cardBackgroundColor="@color/vendor_dark_card"
        app:strokeWidth="1dp"
        app:strokeColor="@color/vendor_dark_border"
        app:cardUseCompatPadding="false">

        <TextView
            android:id="@+id/tv_category_emoji"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="🍔"
            android:textSize="26sp"
            android:singleLine="true"
            android:maxLines="1" />
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:id="@+id/tv_category_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Burger"
        android:textColor="@color/vendor_dark_text_secondary"
        android:textSize="12sp"
        android:textStyle="bold"
        android:ellipsize="end"
        android:maxLines="1"
        android:gravity="center" />

    <!-- Selected Underline Indicator -->
    <View
        android:id="@+id/view_selected_indicator"
        android:layout_width="16dp"
        android:layout_height="3dp"
        android:layout_marginTop="4dp"
        android:background="@drawable/bg_badge_orange"
        android:visibility="invisible" />

</LinearLayout>
