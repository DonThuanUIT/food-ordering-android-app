<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/vendor_dark_bg">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/vendor_dark_bg"
        app:elevation="0dp">
        <androidx.appcompat.widget.Toolbar
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/vendor_dark_bg">
            <ImageView
                android:id="@+id/btn_back_dialog"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_back"
                app:tint="@color/vendor_dark_text_primary"
                android:clickable="true"
                android:focusable="true"
                android:padding="12dp"
                android:background="?attr/selectableItemBackgroundBorderless"/>
            <TextView
                android:id="@+id/tv_dialog_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Thêm món ăn"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/vendor_dark_text_primary"
                android:layout_marginStart="24dp"/>
        </androidx.appcompat.widget.Toolbar>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginBottom="88dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"
        android:clipToPadding="false"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="20dp"
            android:paddingBottom="24dp"> <!-- Leaves enough empty space at bottom so Price field rolls above the bottom button -->

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="180dp">

                <LinearLayout
                    android:id="@+id/upload_area"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_dashed_border"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:clickable="true"
                    android:focusable="true"
                    android:backgroundTint="#2B1D1A">
                    <ImageView
                        android:id="@+id/img_upload_preview"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@drawable/ic_camera_add"
                        app:tint="#8A7D79"
                        android:padding="32dp"/>
                </LinearLayout>

                <ProgressBar
                    android:id="@+id/progress_upload"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_gravity="center"
                    android:visibility="gone"
                    android:indeterminateTint="@color/vendor_dark_orange"/>
            </FrameLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Ảnh chất lượng cao giúp tăng doanh thu."
                android:textSize="12sp"
                android:textColor="#8A7D79"
                android:layout_marginTop="12dp"
                android:textAlignment="center"/>

            <TextView style="@style/LabelStyle" android:text="Tên món ăn" android:textColor="#8A7D79" android:layout_marginTop="20dp"/>
            <EditText
                android:id="@+id/et_food_name"
                style="@style/InputStyle"
                android:hint="Ví dụ: Cánh gà sốt cay"
                android:background="@drawable/bg_vendor_input_dark"
                android:textColor="@color/vendor_dark_text_primary"
                android:textColorHint="#8A7D79"
                android:importantForAutofill="no"/>

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="8dp">
                <TextView
                    style="@style/LabelStyle"
                    android:text="Danh mục"
                    android:textColor="#8A7D79"
                    android:layout_marginTop="0dp"
                    android:layout_marginBottom="0dp"
                    android:layout_centerVertical="true"/>
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true">
                    <TextView
                        android:id="@+id/btn_edit_category"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sửa"
                        android:textColor="@color/vendor_dark_orange"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:padding="8dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:layout_marginEnd="12dp"
                        android:background="?attr/selectableItemBackground"
                        android:visibility="gone"/>
                    <TextView
                        android:id="@+id/btn_add_category"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="+ Mới"
                        android:textColor="@color/vendor_dark_orange"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:padding="8dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackground"/>
                </LinearLayout>
            </RelativeLayout>

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chip_group_category"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:singleSelection="true"
                app:selectionRequired="true"
                android:layout_marginBottom="12dp">
                <!-- Categories will be added dynamically -->
            </com.google.android.material.chip.ChipGroup>

            <TextView style="@style/LabelStyle" android:text="Mô tả chi tiết" android:textColor="#8A7D79"/>
            <EditText
                android:id="@+id/et_food_description"
                style="@style/InputStyle"
                android:layout_height="100dp"
                android:gravity="top|start"
                android:paddingVertical="12dp"
                android:hint="Mô tả nguyên liệu, hương vị..."
                android:background="@drawable/bg_vendor_input_dark"
                android:textColor="@color/vendor_dark_text_primary"
                android:textColorHint="#8A7D79"
                android:importantForAutofill="no"/>

            <TextView style="@style/LabelStyle" android:text="Giá tiền (đ)" android:textColor="#8A7D79"/>
            <EditText
                android:id="@+id/et_food_price"
                style="@style/InputStyle"
                android:hint="0"
                android:inputType="numberDecimal"
                android:background="@drawable/bg_vendor_input_dark"
                android:textColor="@color/vendor_dark_text_primary"
                android:textColorHint="#8A7D79"
                android:importantForAutofill="no"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        app:cardElevation="8dp"
        app:cardBackgroundColor="@color/vendor_dark_bg">
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_add_to_menu"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_margin="16dp"
            android:text="Thêm vào thực đơn"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:backgroundTint="@color/vendor_dark_orange"
            app:cornerRadius="12dp"/>
    </androidx.cardview.widget.CardView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>