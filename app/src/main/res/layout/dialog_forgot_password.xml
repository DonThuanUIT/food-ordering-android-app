<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#FFFFFF"
    android:padding="24dp">

    <!-- Title -->
    <TextView
        android:id="@+id/dialogTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Quên Mật Khẩu 🔑"
        android:textColor="#1A1D26"
        android:textSize="20sp"
        android:textStyle="bold"
        android:gravity="center_horizontal"
        android:layout_marginBottom="8dp"/>

    <!-- Subtitle -->
    <TextView
        android:id="@+id/dialogSubtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Nhập email của bạn để nhận mã OTP khôi phục mật khẩu."
        android:textColor="#718096"
        android:textSize="14sp"
        android:gravity="center_horizontal"
        android:layout_marginBottom="20dp"/>

    <!-- EMAIL INPUT FIELD -->
    <LinearLayout
        android:id="@+id/layoutEmailInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="EMAIL ĐĂNG KÝ"
            android:textColor="#4A5568"
            android:textStyle="bold"
            android:textSize="11sp"/>

        <EditText
            android:id="@+id/dialogEdtEmail"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="6dp"
            android:background="@drawable/bg_edittext"
            android:hint="email@example.com"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:inputType="textEmailAddress"
            android:textColor="#1A1D26"
            android:textColorHint="#A0AEC0"/>

        <Button
            android:id="@+id/dialogBtnSendOtp"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="16dp"
            android:text="Gửi mã OTP"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:background="@drawable/home_bg_button_orange"
            app:backgroundTint="@null"/>
    </LinearLayout>

    <!-- OTP & NEW PASSWORD FIELDS (Initially GONE) -->
    <LinearLayout
        android:id="@+id/layoutResetFields"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone">

        <!-- OTP Code -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MÃ OTP"
            android:textColor="#4A5568"
            android:textStyle="bold"
            android:textSize="11sp"/>

        <EditText
            android:id="@+id/dialogEdtOtp"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="6dp"
            android:background="@drawable/bg_edittext"
            android:hint="Nhập mã OTP 6 số"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:inputType="number"
            android:textColor="#1A1D26"
            android:textColorHint="#A0AEC0"
            android:maxLength="6"/>

        <!-- New Password -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MẬT KHẨU MỚI"
            android:textColor="#4A5568"
            android:textStyle="bold"
            android:textSize="11sp"
            android:layout_marginTop="12dp"/>

        <EditText
            android:id="@+id/dialogEdtNewPassword"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="6dp"
            android:background="@drawable/bg_edittext"
            android:hint="Tối thiểu 8 ký tự, gồm chữ và số"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:inputType="textPassword"
            android:textColor="#1A1D26"
            android:textColorHint="#A0AEC0"/>

        <!-- Confirm New Password -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="XÁC NHẬN MẬT KHẨU MỚI"
            android:textColor="#4A5568"
            android:textStyle="bold"
            android:textSize="11sp"
            android:layout_marginTop="12dp"/>

        <EditText
            android:id="@+id/dialogEdtConfirmNewPassword"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="6dp"
            android:background="@drawable/bg_edittext"
            android:hint="Nhập lại mật khẩu mới"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:inputType="textPassword"
            android:textColor="#1A1D26"
            android:textColorHint="#A0AEC0"/>

        <Button
            android:id="@+id/dialogBtnResetPassword"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="20dp"
            android:text="Đặt lại mật khẩu"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:background="@drawable/home_bg_button_orange"
            app:backgroundTint="@null"/>
    </LinearLayout>

</LinearLayout>
