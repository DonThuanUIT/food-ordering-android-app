<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_shop_detail_panel"
    android:padding="20dp">

    <!-- Handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:background="#E2E8F0"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp"/>

    <!-- Header: Title & Status -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp">
        <TextView
            android:id="@+id/tv_detail_order_id"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Đơn hàng #------"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/vendor_dark_text_primary"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"/>
        <TextView
            android:id="@+id/tv_detail_order_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PENDING"
            android:textColor="@color/white"
            android:textSize="12sp"
            android:textStyle="bold"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:background="@drawable/bg_badge_orange"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"/>
    </RelativeLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/vendor_dark_divider"
        android:layout_marginBottom="16dp"/>

    <!-- Section: Customer Details -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Thông tin giao hàng"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="@color/vendor_dark_text_secondary"
        android:layout_marginBottom="8dp"/>

    <!-- Customer Card -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bg_input"
        android:padding="12dp"
        android:layout_marginBottom="12dp">
        
        <ImageView
            android:id="@+id/iv_customer_icon"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_profile"
            app:tint="@color/vendor_dark_text_secondary"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"/>
            
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_toEndOf="@id/iv_customer_icon"
            android:layout_toStartOf="@+id/btn_chat_customer"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="8dp"
            android:layout_centerVertical="true">
            <TextView
                android:id="@+id/tv_detail_customer_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Họ tên khách hàng"
                android:textColor="@color/vendor_dark_text_primary"
                android:textSize="14sp"
                android:textStyle="bold"/>
            <TextView
                android:id="@+id/tv_detail_customer_phone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📞 0123 456 789"
                android:textColor="@color/vendor_dark_text_secondary"
                android:textSize="13sp"
                android:layout_marginTop="2dp"
                android:clickable="true"
                android:focusable="true"/>
        </LinearLayout>

        <ImageView
            android:id="@+id/btn_chat_customer"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_contact"
            app:tint="@color/vendor_dark_orange"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:padding="6dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true" />
    </RelativeLayout>

    <!-- Location Label -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/vendor_light_orange_soft"
        android:padding="12dp"
        android:layout_marginBottom="16dp">
        <TextView
            android:id="@+id/tv_detail_building"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tòa nhận: Tòa A"
            android:textColor="@color/vendor_dark_text_primary"
            android:textSize="14sp"
            android:textStyle="bold"/>
    </LinearLayout>

    <!-- Section: Shop Details -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Thông tin cửa hàng"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="@color/vendor_dark_text_secondary"
        android:layout_marginBottom="8dp"/>

    <!-- Shop Card -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bg_input"
        android:padding="12dp"
        android:layout_marginBottom="16dp">

        <ImageView
            android:id="@+id/iv_shop_icon"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_store"
            app:tint="@color/vendor_dark_text_secondary"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"/>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_toEndOf="@id/iv_shop_icon"
            android:layout_toStartOf="@+id/btn_chat_shop"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="8dp"
            android:layout_centerVertical="true">
            <TextView
                android:id="@+id/tv_detail_shop_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tên quán ăn"
                android:textColor="@color/vendor_dark_text_primary"
                android:textSize="14sp"
                android:textStyle="bold"/>
            <TextView
                android:id="@+id/tv_detail_shop_address"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Địa chỉ lấy hàng"
                android:textColor="@color/vendor_dark_text_secondary"
                android:textSize="13sp"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <ImageView
            android:id="@+id/btn_chat_shop"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_contact"
            app:tint="@color/vendor_dark_orange"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:padding="6dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true" />
    </RelativeLayout>

    <!-- Section: Items Ordered -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Chi tiết món ăn"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="@color/vendor_dark_text_secondary"
        android:layout_marginBottom="8dp"/>

    <LinearLayout
        android:id="@+id/layout_detail_order_items"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="16dp">
        <!-- Dynamically populated items -->
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/vendor_dark_divider"
        android:layout_marginBottom="16dp"/>

    <!-- Pricing Summary -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="24dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tạm tính (Tiền món)"
                android:textColor="@color/vendor_dark_text_secondary"
                android:textSize="13sp"
                android:layout_alignParentStart="true"/>
            <TextView
                android:id="@+id/tv_detail_subtotal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0đ"
                android:textColor="@color/vendor_dark_text_secondary"
                android:textSize="13sp"
                android:layout_alignParentEnd="true"/>
        </RelativeLayout>

        <RelativeLayout
            android:id="@+id/layout_detail_shipping"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Phí vận chuyển"
                android:textColor="@color/vendor_dark_text_secondary"
                android:textSize="13sp"
                android:layout_alignParentStart="true"/>
            <TextView
                android:id="@+id/tv_detail_shipping"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0đ"
                android:textColor="@color/vendor_dark_text_secondary"
                android:textSize="13sp"
                android:layout_alignParentEnd="true"/>
        </RelativeLayout>

        <RelativeLayout
            android:id="@+id/layout_detail_discount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:visibility="gone">
            <TextView
                android:id="@+id/tv_detail_discount_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Khuyến mãi (Voucher)"
                android:textColor="@color/vendor_dark_text_secondary"
                android:textSize="13sp"
                android:layout_alignParentStart="true"/>
            <TextView
                android:id="@+id/tv_detail_discount_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="-0đ"
                android:textColor="#E53E3E"
                android:textSize="13sp"
                android:layout_alignParentEnd="true"/>
        </RelativeLayout>

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tổng cộng (Khách trả)"
                android:textColor="@color/vendor_dark_text_primary"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_alignParentStart="true"/>
            <TextView
                android:id="@+id/tv_detail_total"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0đ"
                android:textColor="@color/vendor_dark_orange"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_alignParentEnd="true"/>
        </RelativeLayout>
    </LinearLayout>

    <!-- Close Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_close_detail"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="Đóng"
        android:textSize="14sp"
        android:textColor="@color/vendor_dark_text_primary"
        android:backgroundTint="@color/vendor_btn_secondary_bg"
        app:cornerRadius="10dp"/>
</LinearLayout>
