<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_shop_detail_panel"
    android:padding="20dp">

    <!-- Handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:background="#E2E8F0"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp"/>

    <!-- Title -->
    <TextView
        android:id="@+id/tv_food_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tên món ăn"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#1A202C"
        android:layout_marginBottom="20dp"
        android:textAlignment="center"/>

    <!-- Option 1: Edit -->
    <LinearLayout
        android:id="@+id/layout_option_edit"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true"
        android:paddingHorizontal="16dp"
        android:layout_marginBottom="8dp">
        
        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_edit_avatar"
            app:tint="@color/primary_orange"/>
            
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Chỉnh sửa thông tin món ăn"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#2D3748"
            android:layout_marginStart="16dp"/>
    </LinearLayout>

    <!-- Option 2: Delete -->
    <LinearLayout
        android:id="@+id/layout_option_delete"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true"
        android:paddingHorizontal="16dp">
        
        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_delete_outline"
            app:tint="#E53E3E"/>
            
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Xóa món ăn khỏi thực đơn"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#E53E3E"
            android:layout_marginStart="16dp"/>
    </LinearLayout>
</LinearLayout>
