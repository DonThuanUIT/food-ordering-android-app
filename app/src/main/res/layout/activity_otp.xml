<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F6F7F9"
    tools:context=".ui.auth.OtpActivity">

    <View
        android:id="@+id/topBackground"
        android:layout_width="0dp"
        android:layout_height="294dp"
        android:background="@drawable/home_bg_top_dark"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_marginStart="18dp"
        android:layout_marginTop="22dp"
        android:background="@drawable/bg_circle_white"
        android:contentDescription="Back"
        android:elevation="3dp"
        android:padding="12dp"
        android:scaleType="centerInside"
        android:src="@drawable/ic_back"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvOtpTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="28dp"
        android:layout_marginTop="94dp"
        android:layout_marginEnd="28dp"
        android:gravity="center"
        android:text="X&#225;c th&#7921;c OTP"
        android:textColor="#FFFFFF"
        android:textSize="30sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvOtpSubtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="38dp"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="38dp"
        android:gravity="center"
        android:lineSpacingExtra="3dp"
        android:text="Nh&#7853;p m&#227; x&#225;c th&#7921;c &#273;&#7875; ti&#7871;p t&#7909;c"
        android:textColor="#DDE1F0"
        android:textSize="15sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvOtpTitle" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/otpScroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="28dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.cardview.widget.CardView
            android:id="@+id/otpCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="196dp"
            android:layout_marginBottom="28dp"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="26dp"
            app:cardElevation="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:paddingStart="22dp"
                android:paddingTop="28dp"
                android:paddingEnd="22dp"
                android:paddingBottom="26dp">

                <FrameLayout
                    android:layout_width="82dp"
                    android:layout_height="82dp"
                    android:background="@drawable/bg_shop_logo_circle"
                    android:padding="14dp">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:contentDescription="@string/app_name"
                        android:scaleType="centerInside"
                        android:src="@drawable/logo_food" />
                </FrameLayout>

                <TextView
                    android:id="@+id/tvEmailHeader"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:gravity="center"
                    android:lineSpacingExtra="3dp"
                    android:text="M&#227; &#273;&#227; &#273;&#432;&#7907;c g&#7917;i t&#7899;i: email@example.com"
                    android:textColor="#4D587A"
                    android:textSize="15sp" />

                <EditText
                    android:id="@+id/edtOtp"
                    android:layout_width="match_parent"
                    android:layout_height="68dp"
                    android:layout_marginTop="28dp"
                    android:background="@drawable/bg_otp_input"
                    android:gravity="center"
                    android:hint="000000"
                    android:importantForAutofill="yes"
                    android:inputType="number"
                    android:letterSpacing="0.28"
                    android:maxLength="6"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:textColor="#111111"
                    android:textColorHint="#B8BDC9"
                    android:textSize="30sp"
                    android:textStyle="bold"
                    android:autofillHints="smsOTPCode" />

                <Button
                    android:id="@+id/btnVerify"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="22dp"
                    android:background="@drawable/home_bg_button_orange"
                    android:text="X&#225;c nh&#7853;n"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    app:backgroundTint="@null" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvTimer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="G&#7917;i l&#7841;i sau 05:00"
                        android:textColor="#8A8F9F"
                        android:textSize="14sp" />

                    <Button
                        android:id="@+id/btnResend"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="44dp"
                        android:layout_marginTop="4dp"
                        android:enabled="false"
                        android:minWidth="0dp"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:text="G&#7917;i l&#7841;i m&#227;"
                        android:textAllCaps="false"
                        android:textColor="#FF7A21"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </androidx.core.widget.NestedScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
