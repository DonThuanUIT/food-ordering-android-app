<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingVertical="14dp">

    <ImageView
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:background="@drawable/bg_admin_avatar"
        android:padding="12dp"
        android:src="@drawable/ic_store"
        app:tint="#B24C08" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvAdminPendingShopName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/black"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvAdminPendingShopOwner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="#6D4C41"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvAdminPendingShopStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_admin_status_pending"
            android:paddingHorizontal="12dp"
            android:paddingVertical="4dp"
            android:textColor="#B24C08"
            android:textSize="11sp"
            android:textStyle="bold" />
    </LinearLayout>

    <ImageView
        android:layout_width="22dp"
        android:layout_height="22dp"
        android:src="@drawable/ic_chevron_right"
        app:tint="#A8A8A8" />
</LinearLayout>
